# =============================================================================
# .env.example — copy to `.env` (or `.env.development` / `.env.production`)
# Real values for these variables MUST NOT be committed to the repository.
# `.gitignore` blocks `.env*` (except this file).
# =============================================================================

# ---------- Client (browser-bundled, must use VITE_ prefix) ------------------
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PROJECT_ID="<project-ref>"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase-anon-jwt>"
VITE_PAYMENTS_CLIENT_TOKEN="pk_test_xxx_or_pk_live_xxx"
VITE_PUBLIC_SITE_URL="https://example.com"

# ---------- Server-only (NEVER expose to the browser) ------------------------
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<supabase-anon-jwt>"
SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-jwt>"

# HMAC secret used to sign portal presentation tokens.
# Must be a long, random, high-entropy string.
PRESENTATION_TOKEN_SECRET="<32+-byte-random-string>"

# Lovable AI gateway credentials used by server functions and edge functions.
LOVABLE_API_KEY="<lovable-gateway-key>"
LOVABLE_SEND_URL=""

# Shared secret used by /api/geocode-beacon to authorise internal callers.
INTERNAL_GEOCODE_SECRET="<32+-byte-random-string>"

# =============================================================================
# Supabase Edge Function secrets (configured in Supabase dashboard, NOT here):
#   PAYMENTS_SANDBOX_WEBHOOK_SECRET, PAYMENTS_LIVE_WEBHOOK_SECRET,
#   PAYMENTS_SANDBOX_API_KEY, PAYMENTS_LIVE_API_KEY,
#   GEMINI_API_KEY, GROQ_API_KEY, BYOK_MASTER_KEY, ...
# =============================================================================
